{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "dist",
    "coverage",
    "**/*.md",
    "**/*.mdx",
    "**/*.yml",
    "**/*.yaml",
    "**/*.toml",
    "**/*.html",
    "**/*.css",
    "**/*.scss",
    "**/*.less",
    "**/*.graphql",
    "**/*.gql"
  ]
}
