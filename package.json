{
  "name": "ghst",
  "version": "0.3.0",
  "description": "A modern Ghost CMS CLI",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ghst": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "fixtures:ghost:update": "tsx scripts/update-ghost-fixtures.ts",
    "fixtures:ghost:check": "tsx scripts/update-ghost-fixtures.ts --check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format:check": "biome format .",
    "format": "biome format --write .",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@tryghost/mg-json": "^0.11.13",
    "@tryghost/mg-medium-export": "^0.17.26",
    "@tryghost/mg-substack": "^0.8.9",
    "@tryghost/mg-wp-xml": "^0.5.20",
    "@tryghost/string": "^0.2.21",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "conf": "^14.0.0",
    "csv-parse": "^6.1.0",
    "gscan": "^5.2.5",
    "ink": "^6.5.1",
    "jose": "^6.1.3",
    "markdown-it": "^14.1.1",
    "ora": "^9.0.0",
    "react": "^19.2.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@vitest/coverage-v8": "^4.0.8",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
