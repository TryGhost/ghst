{
  "name": "@tryghost/ghst",
  "version": "0.15.0",
  "description": "A modern Ghost CMS CLI",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/ghst.git"
  },
  "homepage": "https://github.com/TryGhost/ghst#readme",
  "bugs": {
    "url": "https://github.com/TryGhost/ghst/issues"
  },
  "bin": {
    "ghst": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^22.13.0 || ^24.0.0 || ^26.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "fixtures:ghost:capture": "tsx scripts/capture-ghost-fixtures.ts",
    "fixtures:ghost:check": "tsx scripts/check-ghost-fixtures.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format:check": "biome format .",
    "format": "biome format --write .",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tryghost/mg-json": "0.21.0",
    "@tryghost/mg-medium-export": "0.26.0",
    "@tryghost/mg-substack": "1.5.0",
    "@tryghost/mg-wp-xml": "0.16.0",
    "@tryghost/string": "0.3.5",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "15.0.0",
    "conf": "15.1.0",
    "csv-parse": "6.2.1",
    "gscan": "6.2.1",
    "ink": "7.0.5",
    "jose": "6.2.3",
    "markdown-it": "14.2.0",
    "ora": "9.4.0",
    "react": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@vitest/coverage-v8": "4.1.8",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
