{
  "name": "@tryghost/ghst",
  "version": "0.4.3",
  "description": "A modern Ghost CMS CLI",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/ghst.git"
  },
  "homepage": "https://github.com/TryGhost/ghst#readme",
  "bugs": {
    "url": "https://github.com/TryGhost/ghst/issues"
  },
  "bin": {
    "ghst": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "fixtures:ghost:update": "tsx scripts/update-ghost-fixtures.ts",
    "fixtures:ghost:check": "tsx scripts/update-ghost-fixtures.ts --check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format:check": "biome format .",
    "format": "biome format --write .",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@tryghost/mg-json": "0.11.13",
    "@tryghost/mg-medium-export": "0.17.27",
    "@tryghost/mg-substack": "0.8.10",
    "@tryghost/mg-wp-xml": "0.5.21",
    "@tryghost/string": "0.3.1",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "conf": "15.1.0",
    "csv-parse": "6.1.0",
    "gscan": "5.2.5",
    "ink": "6.8.0",
    "jose": "6.1.3",
    "markdown-it": "14.1.1",
    "ora": "9.3.0",
    "react": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "4.0.18",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
