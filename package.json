{
  "name": "@tryghost/ghst",
  "version": "0.16.2",
  "description": "A modern Ghost CMS CLI",
  "homepage": "https://github.com/TryGhost/ghst#readme",
  "bugs": {
    "url": "https://github.com/TryGhost/ghst/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/ghst.git"
  },
  "bin": {
    "ghst": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "fixtures:ghost:capture": "tsx scripts/capture-ghost-fixtures.ts",
    "fixtures:ghost:check": "tsx scripts/check-ghost-fixtures.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format:check": "oxfmt --check",
    "format": "oxfmt",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@jq-tools/jq": "0.0.11",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tryghost/mg-json": "0.22.2",
    "@tryghost/mg-medium-export": "0.27.2",
    "@tryghost/mg-substack": "1.8.0",
    "@tryghost/mg-wp-xml": "0.17.2",
    "@tryghost/string": "0.3.5",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "15.0.0",
    "conf": "15.1.0",
    "csv-parse": "7.0.1",
    "gscan": "6.4.2",
    "ink": "7.1.1",
    "jose": "6.2.3",
    "markdown-it": "14.3.0",
    "ora": "9.4.1",
    "react": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@vitest/coverage-v8": "4.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "^22.13.0 || ^24.0.0 || ^26.0.0"
  },
  "packageManager": "pnpm@11.14.0"
}
