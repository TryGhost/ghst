              "default": "Logo on cover",
              "options": ["Logo on cover", "Logo in the middle", "Stacked"],
              "type": "select"
            },
            "post_image_style": {
              "default": "Wide",
              "group": "post",
              "options": ["Wide", "Full", "Small", "Hidden"],
              "type": "select"
            },
            "show_publication_cover": {
              "default": true,
              "group": "homepage",
              "type": "boolean"
            },
            "show_recent_posts_footer": {
              "default": true,
              "group": "post",
              "type": "boolean"
            },
            "title_font": {
              "default": "Modern sans-serif",
              "options": ["Modern sans-serif", "Elegant serif"],
              "type": "select"
            }
          },
          "image_sizes": {
            "l": {
              "width": 1000
            },
            "m": {
              "width": 600
            },
            "s": {
              "width": 300
            },
            "xl": {
              "width": 2000
            },
            "xs": {
              "width": 100
            },
            "xxs": {
              "width": 30
            }
          },
          "posts_per_page": 25
        },
        "contributors": "https://github.com/TryGhost/Casper/graphs/contributors",
        "demo": "https://demo.ghost.io",
        "description": "A clean, minimal default theme for the Ghost publishing platform",
        "devDependencies": {
          "@tryghost/release-utils": "0.8.1",
          "autoprefixer": "10.4.7",
          "beeper": "2.1.0",
          "cssnano": "5.1.12",
          "gscan": "4.48.0",
          "gulp": "4.0.2",
          "gulp-concat": "2.6.1",
          "gulp-livereload": "4.0.2",
          "gulp-postcss": "9.0.1",
          "gulp-uglify": "3.0.2",
          "gulp-zip": "5.1.0",
          "inquirer": "8.2.4",
          "postcss": "8.2.13",
          "postcss-color-mod-function": "3.0.3",
          "postcss-easy-import": "4.0.0",
          "pump": "3.0.0"
        },
        "engines": {
          "ghost": ">=5.0.0"
        },
        "gpm": {
          "categories": ["Minimal", "Magazine"],
          "type": "theme"
        },
        "keywords": ["ghost", "theme", "ghost-theme"],
        "license": "MIT",
        "name": "casper",
        "renovate": {
          "extends": ["@tryghost:theme"]
        },
        "repository": {
          "type": "git",
          "url": "https://github.com/TryGhost/Casper.git"
        },
        "screenshots": {
          "desktop": "assets/screenshot-desktop.jpg",
          "mobile": "assets/screenshot-mobile.jpg"
        },
        "scripts": {
          "dev": "gulp",
          "postship": "git fetch && gulp release",
          "preship": "yarn test",
          "pretest": "gulp build",
          "ship": "STATUS=$(git status --porcelain); echo $STATUS; if [ -z \"$STATUS\" ]; then yarn version && git push --follow-tags; else echo \"Uncomitted changes found.\" && exit 1; fi",
          "test": "gscan .",
          "test:ci": "gscan --fatal --verbose .",
          "zip": "gulp zip"
        },
        "version": "5.9.0"
      }
